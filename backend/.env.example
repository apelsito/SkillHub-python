# --- App ---
SKILLHUB_APP_NAME=skillhub
SKILLHUB_PUBLIC_BASE_URL=
SKILLHUB_ACCESS_POLICY_MODE=OPEN

# --- Server ---
SERVER_PORT=8080
SERVER_SERVLET_SESSION_TIMEOUT=PT8H
SESSION_COOKIE_SECURE=false

# --- Database (Postgres 16) ---
SPRING_DATASOURCE_URL=postgresql+asyncpg://skillhub:skillhub_dev@127.0.0.1:5432/skillhub
SPRING_DATASOURCE_USERNAME=skillhub
SPRING_DATASOURCE_PASSWORD=skillhub_dev
DB_POOL_MAX_SIZE=10

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
SESSION_REDIS_NAMESPACE=skillhub:session

# --- OAuth2 ---
OAUTH2_GITHUB_CLIENT_ID=placeholder
OAUTH2_GITHUB_CLIENT_SECRET=placeholder
OAUTH2_GITLAB_CLIENT_ID=placeholder
OAUTH2_GITLAB_CLIENT_SECRET=placeholder
OAUTH2_GITLAB_BASE_URI=https://gitlab.com
OAUTH2_GITLAB_DISPLAY_NAME=GitLab

# --- Mail ---
SPRING_MAIL_HOST=127.0.0.1
SPRING_MAIL_PORT=25
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false

# --- Auth feature flags ---
SKILLHUB_AUTH_MOCK_ENABLED=false
SKILLHUB_AUTH_DIRECT_ENABLED=false
SKILLHUB_AUTH_SESSION_BOOTSTRAP_ENABLED=false
SKILLHUB_AUTH_PASSWORD_RESET_CODE_EXPIRY=PT10M
SKILLHUB_AUTH_PASSWORD_RESET_FROM_ADDRESS=noreply@skillhub.local
SKILLHUB_AUTH_PASSWORD_RESET_FROM_NAME=SkillHub

# --- Storage ---
SKILLHUB_STORAGE_PROVIDER=local
STORAGE_BASE_PATH=/tmp/skillhub-storage
SKILLHUB_STORAGE_S3_ENDPOINT=
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=
SKILLHUB_STORAGE_S3_BUCKET=skillhub
SKILLHUB_STORAGE_S3_ACCESS_KEY=
SKILLHUB_STORAGE_S3_SECRET_KEY=
SKILLHUB_STORAGE_S3_REGION=us-east-1
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=true
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=false
SKILLHUB_STORAGE_S3_PRESIGN_EXPIRY=PT10M

# --- Search ---
SKILLHUB_SEARCH_ENGINE=postgres
SKILLHUB_SEARCH_SEMANTIC_ENABLED=true
SKILLHUB_SEARCH_SEMANTIC_WEIGHT=0.35
SKILLHUB_SEARCH_SEMANTIC_CANDIDATE_MULTIPLIER=8
SKILLHUB_SEARCH_SEMANTIC_MAX_CANDIDATES=120
SKILLHUB_SEARCH_REBUILD_ON_STARTUP=false

# --- Rate limit ---
SKILLHUB_DOWNLOAD_ANON_COOKIE_NAME=skillhub_anon_dl
SKILLHUB_DOWNLOAD_ANON_COOKIE_MAX_AGE=P30D
SKILLHUB_DOWNLOAD_ANON_COOKIE_SECRET=change-me-in-production

# --- Publish limits ---
SKILLHUB_PUBLISH_MAX_FILE_COUNT=500
SKILLHUB_PUBLISH_MAX_SINGLE_FILE_SIZE=10485760
SKILLHUB_PUBLISH_MAX_PACKAGE_SIZE=104857600

# --- Labels ---
SKILLHUB_LABEL_MAX_DEFINITIONS=100
SKILLHUB_LABEL_MAX_PER_SKILL=10

# --- Profile moderation ---
SKILLHUB_PROFILE_MACHINE_REVIEW_ENABLED=true
SKILLHUB_PROFILE_HUMAN_REVIEW_ENABLED=true

# --- Device auth ---
DEVICE_AUTH_VERIFICATION_URI=

# --- Scanner ---
SKILLHUB_SECURITY_SCANNER_ENABLED=false
SKILLHUB_SECURITY_SCANNER_URL=http://127.0.0.1:8000
SKILLHUB_SECURITY_SCANNER_MODE=local
SKILLHUB_SECURITY_SCANNER_CONNECT_TIMEOUT=5000
SKILLHUB_SECURITY_SCANNER_READ_TIMEOUT=300000
SKILLHUB_SECURITY_SCANNER_RETRY_MAX=3

# --- Scan stream ---
SKILLHUB_SCAN_STREAM_KEY=skillhub:scan:requests
SKILLHUB_SCAN_STREAM_GROUP=skillhub-scanners
SKILLHUB_SCAN_STREAM_RECLAIM_ENABLED=true
SKILLHUB_SCAN_STREAM_RECLAIM_MIN_IDLE=PT2M
SKILLHUB_SCAN_STREAM_RECLAIM_BATCH_SIZE=20
SKILLHUB_SCAN_STREAM_RECLAIM_INTERVAL=PT30S

# --- Bootstrap admin ---
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USER_ID=docker-admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@skillhub.local
