# --- production overrides for compose.release.yml ---
# Copy to `.env.release`, fill in the secrets, and keep the file out of git.

# App
SKILLHUB_APP_NAME=skillhub
SKILLHUB_PUBLIC_BASE_URL=https://skillhub.example.com

# Server
SESSION_COOKIE_SECURE=true
SERVER_SERVLET_SESSION_TIMEOUT=PT8H

# Database
SPRING_DATASOURCE_URL=postgresql+asyncpg://skillhub:CHANGE_ME@postgres:5432/skillhub
SPRING_DATASOURCE_USERNAME=skillhub
SPRING_DATASOURCE_PASSWORD=CHANGE_ME
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=CHANGE_ME
DB_POOL_MAX_SIZE=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# Storage
SKILLHUB_STORAGE_PROVIDER=s3
SKILLHUB_STORAGE_S3_ENDPOINT=http://minio:9000
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=https://skillhub.example.com/s3
SKILLHUB_STORAGE_S3_BUCKET=skillhub
SKILLHUB_STORAGE_S3_ACCESS_KEY=CHANGE_ME
SKILLHUB_STORAGE_S3_SECRET_KEY=CHANGE_ME
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=true
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# OAuth2 — production client ids / secrets
OAUTH2_GITHUB_CLIENT_ID=CHANGE_ME
OAUTH2_GITHUB_CLIENT_SECRET=CHANGE_ME
OAUTH2_GITLAB_CLIENT_ID=CHANGE_ME
OAUTH2_GITLAB_CLIENT_SECRET=CHANGE_ME

# Bootstrap admin: only enable on first deploy, then flip to false.
BOOTSTRAP_ADMIN_ENABLED=false

# Scanner
SKILLHUB_SECURITY_SCANNER_ENABLED=true
SKILLHUB_SECURITY_SCANNER_URL=http://scanner:8000

# Docker image tag / registry
DOCKER_NAMESPACE=skillhub
API_IMAGE_TAG=latest
API_PORT=8080
